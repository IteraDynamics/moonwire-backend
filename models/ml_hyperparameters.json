{
  "ensemble": {
    "models": ["lr", "rf", "gb"],
    "weights": {
      "lr": 0.3,
      "rf": 0.4,
      "gb": 0.3
    }
  },
  "lr": {
    "solver": "liblinear",
    "max_iter": 2000,
    "class_weight": "balanced"
  },
  "rf": {
    "n_estimators": 200,
    "max_depth": null,
    "min_samples_split": 2,
    "class_weight": "balanced",
    "random_state": 42,
    "n_jobs": -1
  },
  "gb": {
    "n_estimators": 100,
    "learning_rate": 0.1,
    "max_depth": 3,
    "random_state": 42
  },
  "training": {
    "days_lookback": 14,
    "interval": "hour",
    "train_val_split": 0.8
  }
}
